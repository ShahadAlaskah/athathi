generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum RequestStatus {
  PENDING
  QUOTED
  ACCEPTED
  CANCELLED
}

enum OrderStatus {
  ACCEPTED
  IN_PRODUCTION
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  fullName      String
  phone         String?
  role          Role           @default(CLIENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  provider      Provider?
  requests      FurnitureRequest[]
  offers        Offer[]
  sentMessages  Message[]      @relation("SentMessages")
  notifications Notification[]
  reviewsSent   Review[]       @relation("ReviewsFrom")
  tickets       SupportTicket[]
}

model Provider {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  factoryName String
  city        String
  bio         String?
  rating      Float    @default(0)
  isVerified  Boolean  @default(false)
  
  offers      Offer[]
  orders      Order[]
}

model FurnitureRequest {
  id          String         @id @default(uuid())
  clientId    String
  client      User           @relation(fields: [clientId], references: [id])
  title       String
  description String
  category    String
  dimensions  String
  material    String?
  color       String?
  quantity    Int            @default(1)
  city        String
  budget      Float?
  deadline    DateTime?
  withInstallation Boolean   @default(false)
  status      RequestStatus  @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  images      RequestImage[]
  offers      Offer[]
}

model RequestImage {
  id               String           @id @default(uuid())
  requestId        String
  request          FurnitureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  url              String
  createdAt        DateTime         @default(now())
}

model Offer {
  id              String           @id @default(uuid())
  requestId       String
  request         FurnitureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  providerId      String
  provider        Provider         @relation(fields: [providerId], references: [id])
  userId          String           // Direct link to provider's user record for easier queries
  user            User             @relation(fields: [userId], references: [id])
  price           Float
  estimatedDays   Int
  proposedMaterials String?
  warrantyInfo    String?
  deliveryIncluded Boolean         @default(true)
  paymentTerms    String?
  status          String           @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt       DateTime         @default(now())
  
  order           Order?
  conversation    Conversation?
}

model Order {
  id              String           @id @default(uuid())
  offerId         String           @unique
  offer           Offer            @relation(fields: [offerId], references: [id])
  providerId      String
  provider        Provider         @relation(fields: [providerId], references: [id])
  status          OrderStatus      @default(ACCEPTED)
  totalAmount     Float
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  history         OrderStatusHistory[]
  payment         Payment?
  review          Review?
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
}

model Conversation {
  id        String           @id @default(uuid())
  offerId   String           @unique
  offer     Offer            @relation(fields: [offerId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String
  createdAt      DateTime     @default(now())
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id])
  stripeSessionId   String        @unique
  amount            Float
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  fromId     String
  from       User     @relation("ReviewsFrom", fields: [fromId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  isRead    Boolean  @default(false)
  type      String?
  createdAt DateTime @default(now())
}

model Advertisement {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  link      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  message   String
  status    String   @default("OPEN") // OPEN, CLOSED, IN_PROGRESS
  createdAt DateTime @default(now())
}
